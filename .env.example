# Copy to .env and fill in values. .env is gitignored.

# Cloudflare Tunnel token from Zero Trust dashboard → Networks → Tunnels → your tunnel
TUNNEL_TOKEN=eyJhIjoi...replace-me...

# Host user/group IDs so synced files are owned by you (run `id -u` and `id -g`)
PUID=1000
PGID=1000

# Timezone (IANA name)
TZ=Asia/Dubai

# rclone remote name (whatever you chose during `rclone config`)
GDRIVE_REMOTE=gdrive

# Paths inside Google Drive (no leading slash)
GDRIVE_BOOKS_PATH=Books
GDRIVE_AUDIOBOOKS_PATH=Audiobooks

# Sync cadence in seconds (900 = 15 min)
SYNC_INTERVAL_SECONDS=900
